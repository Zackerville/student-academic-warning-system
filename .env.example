# =============================================================
# AI Student Warning System - Environment Variables Template
# Copy file này thành .env trước khi chạy:
# cp .env.example .env
# =============================================================

# ─── APP ─────────────────────────────────────────────────────
PROJECT_NAME=AI Student Warning System
APP_NAME=AI Warning System
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# ─── BACKEND ─────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# ─── DATABASE ────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=warning_ai_db
POSTGRES_USER=warning_user
POSTGRES_PASSWORD=warning_password
DATABASE_URL=postgresql+asyncpg://warning_user:warning_password@db:5432/warning_ai_db

# ─── PGADMIN ─────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin123

# ─── JWT AUTH ────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
ALGORITHM=HS256
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── FRONTEND ─────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=AI Warning System - HCMUT

# ─── REDIS ────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# ─── CELERY ───────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── RAG / LLM ────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

VECTOR_STORE=pgvector

# ─── EMAIL ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@hcmut.edu.vn
EMAIL_FROM_NAME=Hệ thống Cảnh báo Học vụ HCMUT

# ─── LOGGING ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text